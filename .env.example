# how training finds MLflow + MinIO. Convenient env vars for MLflow/MinIO. Copy to .env and export when working locally.

# Where the MLflow server lives (docker-compose exposes it on localhost)
MLFLOW_TRACKING_URI=http://localhost:5500

# Where MLflow should store artifacts (S3-compatible MinIO, host access)
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# MinIO credentials (compose stack sets these inside the containers)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1

# Experiment/registry names (optional; train.py reads MLFLOW_EXPERIMENT_NAME)
MLFLOW_EXPERIMENT_NAME=demo-cv
MLFLOW_REGISTERED_MODEL_NAME=cxr-demo

# Optional (helps boto3 on local dev)
AWS_S3_FORCE_PATH_STYLE=true
AWS_EC2_METADATA_DISABLED=true

