# how training finds MLflow + MinIO. Convenient env vars for MLflow/MinIO. Copy to .env and export when working locally.

# Where the MLflow server lives (docker-compose exposes it on localhost)
MLFLOW_TRACKING_URI=http://localhost:5000

# Where MLflow should store artifacts (S3-compatible MinIO, also local)
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# MinIO credentials (compose stack sets these)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123

# Where your runs appear, and under what registered model name
MLFLOW_EXPERIMENT_NAME=demo-cv
MLFLOW_REGISTERED_MODEL_NAME=cxr-demo
